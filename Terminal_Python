import tkinter as tk
from tkinter import scrolledtext, filedialog, messagebox
import serial
import serial.tools.list_ports
import threading
import os
import pty
import select
import time

class SerialMonitor:
    def __init__(self, root):
        self.root = root
        self.root.title("Python Serial Monitor with PTY")

        # Serial port settings
        self.port_var = tk.StringVar()
        self.baud_var = tk.StringVar(value="115200")

        top_frame = tk.Frame(root)
        top_frame.pack(fill=tk.X, padx=5, pady=5)

        tk.Label(top_frame, text="Port:").pack(side=tk.LEFT)
        self.port_menu = tk.OptionMenu(top_frame, self.port_var, *self.list_ports())
        self.port_menu.pack(side=tk.LEFT, padx=5)

        tk.Label(top_frame, text="Baud:").pack(side=tk.LEFT)
        self.baud_entry = tk.Entry(top_frame, textvariable=self.baud_var, width=8)
        self.baud_entry.pack(side=tk.LEFT, padx=5)

        self.connect_btn = tk.Button(top_frame, text="Connect", command=self.connect_serial)
        self.connect_btn.pack(side=tk.LEFT, padx=5)

        # Terminal area
        self.text_area = scrolledtext.ScrolledText(root, wrap=tk.WORD, height=30, width=100,
                                                   bg="black", fg="white", insertbackground="white")
        self.text_area.pack(padx=5, pady=5, fill=tk.BOTH, expand=True)

        self.text_area.bind("<Key>", self.key_pressed)

        self.ser = None
        self.running = False

    def list_ports(self):
        return [p.device for p in serial.tools.list_ports.comports()]

    def connect_serial(self):
        if self.ser and self.ser.is_open:
            self.running = False
            self.ser.close()
            self.connect_btn.config(text="Connect")
            return

        try:
            port = self.port_var.get()
            baud = int(self.baud_var.get())
            self.ser = serial.Serial(port, baud, timeout=0)
            self.running = True
            self.connect_btn.config(text="Disconnect")
            threading.Thread(target=self.read_serial, daemon=True).start()
        except Exception as e:
            messagebox.showerror("Error", str(e))

    def read_serial(self):
        """Continuously read from serial and display"""
        while self.running:
            try:
                if self.ser.in_waiting:
                    data = self.ser.read(self.ser.in_waiting).decode(errors="ignore")
                    self.text_area.insert(tk.END, data)
                    self.text_area.see(tk.END)
            except Exception as e:
                self.running = False
                break
            time.sleep(0.01)

    def key_pressed(self, event):
        """Send keystrokes to serial port (like TTY)"""
        if not self.ser or not self.ser.is_open:
            return "break"

        if event.char:
            self.ser.write(event.char.encode())
        elif event.keysym == "Return":
            self.ser.write(b"\n")
        elif event.keysym == "BackSpace":
            self.ser.write(b"\x7f")

        return "break"


if __name__ == "__main__":
    root = tk.Tk()
    SerialMonitor(root)
    root.mainloop()
